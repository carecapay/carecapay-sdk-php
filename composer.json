{
    "name": "carecapay/sdk-php",
    "description": "SDK oficial PHP da CarecaPay — cobranças Pix, saldo e verificação de webhooks.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "keywords": [
        "carecapay",
        "pix",
        "pagamentos",
        "gateway",
        "sdk"
    ],
    "homepage": "https://carecapay.com",
    "authors": [
        {
            "name": "CarecaPay"
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "CarecaPay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CarecaPay\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit tests --colors=always"
    }
}
